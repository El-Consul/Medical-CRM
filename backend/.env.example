# Medical CRM backend example environment variables
# IMPORTANT: Use a DIFFERENT Supabase/Postgres DATABASE_URL than other projects

PORT=5000
DATABASE_URL="postgresql://username:password@host:5432/medical_crm?schema=public"
JWT_SECRET="your-secure-jwt-key"

